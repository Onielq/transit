{
  "name": "plateau-transit-backend",
  "version": "1.0.0",
  "description": "Production backend for Plateau Transit — Kigali bus tracking PWA",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "node --watch src/server.js",
    "db:migrate":  "node src/scripts/migrate.js",
    "gtfs:import": "node src/scripts/gtfs-import.js"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "bcryptjs":    "^2.4.3",
    "compression": "^1.7.4",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.18.3",
    "helmet":      "^7.1.0",
    "jsonwebtoken":"^9.0.2",
    "morgan":      "^1.10.0",
    "node-cron":   "^3.0.3",
    "pg":          "^8.11.5",
    "socket.io":   "^4.7.5",
    "zod":         "^3.23.8"
  }
}
