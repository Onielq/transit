# ─────────────────────────────────────────────
# Plateau Transit Backend — Environment Config
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5500

# PostgreSQL (Supabase, Neon, Railway, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/plateau_transit
# Or individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plateau_transit
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# GTFS (when RURA provides a feed)
GTFS_STATIC_URL=https://rura.rw/gtfs/plateau-transit.zip
GTFS_RT_URL=https://rura.rw/gtfs-rt/vehicle-positions

# Crowdsourced GPS — trust threshold
GPS_MIN_REPORTERS=2
GPS_STALE_THRESHOLD_MS=120000

# Optional: Sentry DSN for error tracking
SENTRY_DSN=
